# Cross-platform (WSL / macOS) Development Environment .zshrc

# macOS: initialise Homebrew and put it on PATH before anything else
if [[ "$OSTYPE" == darwin* ]]; then
  if [[ -f /opt/homebrew/bin/brew ]]; then        # Apple Silicon
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [[ -f /usr/local/bin/brew ]]; then          # Intel
    eval "$(/usr/local/bin/brew shellenv)"
  fi
  export CLICOLOR=1   # enables colour for BSD ls without extra flags
fi

# Oh My Zsh configuration
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"  # <- change theme to p10k

plugins=(
    git
    docker
    terraform
    azure
    python
    node
    npm
    direnv
    history-substring-search
    zsh-autosuggestions
    kubectl
)

source $ZSH/oh-my-zsh.sh

# Initialize Powerlevel10k instant prompt (optional, speeds up prompt rendering)
if [[ ! -f ~/.p10k.zsh ]]; then
  # if p10k config doesn't exist, generate default
  p10k configure
fi
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# Environment variables
export EDITOR=vim
export VISUAL=vim

# Initialize conda
if [ -f "$HOME/miniconda/bin/activate" ]; then
    source "$HOME/miniconda/bin/activate"
    export PATH="$HOME/miniconda/bin:$PATH"
fi

# Initialize NVM
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# Initialize direnv
eval "$(direnv hook zsh)"

# Useful aliases
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'
alias ..='cd ..'
alias ...='cd ../..'
alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'

# Git aliases
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gco='git checkout'
alias gb='git branch'
alias gd='git diff'
alias gl='git log --oneline -n 5'
alias gap='git add . && git commit --amend --no-edit && git push -f'

# Azure aliases
alias azls='az account list --output table'
alias azset='az account set --subscription'
alias azshow='az account show'

# Terraform aliases
alias tf='terraform'
alias tfi='terraform init'
alias tfp='terraform plan'
alias tfa='terraform apply'
alias tfd='terraform destroy'
alias tfv='terraform validate'
alias tff='terraform fmt'

# Python aliases
alias py='python'
alias pip='pip'
alias venv='python -m venv'

# Node aliases
alias ni='npm install'
alias nr='npm run'
alias ns='npm start'
alias nt='npm test'
alias nb='npm run build'

# Directory navigation
alias projects='cd ~/projects'
alias home='cd ~'

# Network utilities
alias ports='netstat -tuln'
alias myip='curl -s ifconfig.me'
alias ping='ping -c 5'

# System utilities
alias df='df -h'
alias du='du -h'
[[ "$OSTYPE" != darwin* ]] && alias free='free -h'   # not available on macOS
alias ps='ps aux'
alias top='htop'

# Docker aliases (if Docker is available)
alias d='docker'
alias dc='docker-compose'
alias dps='docker ps'
alias di='docker images'

# Add local bin to PATH
export PATH="$HOME/.local/bin:$PATH"

# Conda


# Load local customizations if they exist
[ -f ~/.zshrc.local ] && source ~/.zshrc.local

# Scaleway CLI autocomplete initialization.
eval "$(scw autocomplete script shell=zsh)"
